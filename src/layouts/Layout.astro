---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Pear Notes is a secure, private, and offline-first notebook. End-to-end encrypted with peer-to-peer sync across all your devices. No servers, no cloud leaks.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const ogImage = new URL(`${base}og-image.png`, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e0e10" />
    <link rel="icon" type="image/png" href={`${base}icon.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      const header = document.querySelector('.header');
      if (header) {
        window.addEventListener('scroll', () => {
          header.classList.toggle('scrolled', window.scrollY > 40);
        });
      }

      const menuBtn = document.querySelector('.mobile-menu-btn');
      const navLinks = document.querySelector('.nav-links');
      if (menuBtn && navLinks) {
        menuBtn.setAttribute('aria-expanded', 'false');
        menuBtn.addEventListener('click', () => {
          const open = navLinks.classList.toggle('open');
          menuBtn.textContent = open ? '✕' : '☰';
          menuBtn.setAttribute('aria-expanded', String(open));
        });
        navLinks.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            navLinks.classList.remove('open');
            menuBtn.textContent = '☰';
            menuBtn.setAttribute('aria-expanded', 'false');
          });
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

      // Active nav link highlighting — page-based (privacy, terms)
      document.querySelectorAll<HTMLAnchorElement>('.nav-links a:not([href*="#"])').forEach(a => {
        const linkPath = new URL(a.href).pathname;
        if (linkPath !== '/' && window.location.pathname === linkPath) {
          a.classList.add('nav-active');
        }
      });

      // Active nav link highlighting — hash-based (sections)
      const navAnchors = document.querySelectorAll<HTMLAnchorElement>('.nav-links a[href*="#"]');
      const sections = Array.from(navAnchors)
        .map(a => {
          const id = a.getAttribute('href')!.split('#')[1];
          return id ? document.getElementById(id) : null;
        })
        .filter(Boolean) as HTMLElement[];

      const setActiveLink = (id: string) => {
        navAnchors.forEach(a => {
          const href = a.getAttribute('href') ?? '';
          a.classList.toggle('nav-active', href.includes(`#${id}`));
        });
      };

      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) setActiveLink(entry.target.id);
          });
        },
        { rootMargin: '-40% 0px -55% 0px', threshold: 0 }
      );

      sections.forEach(s => sectionObserver.observe(s));

      document.querySelectorAll('.feature-list').forEach(list => {
        const wrap = list.closest('.feature-list-wrap');
        if (!wrap) return;
        const check = () => {
          const atTop = list.scrollTop < 8;
          const atBottom = list.scrollHeight - list.scrollTop - list.clientHeight < 8;
          wrap.classList.toggle('scrolled-top', !atTop);
          wrap.classList.toggle('at-bottom', atBottom);
        };
        check();
        list.addEventListener('scroll', check);
      });

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      document.querySelectorAll('.app-showcase').forEach(section => {
        const featureItems = Array.from(section.querySelectorAll<HTMLElement>('.feature-item'));
        const featureScreens = section.querySelectorAll('.feature-screen');
        const platformBtns = section.querySelectorAll('.platform-toggle-btn');
        const list = section.querySelector<HTMLElement>('.feature-list');
        let activePlatform = platformBtns.length > 0 ? platformBtns[0].getAttribute('data-platform')! : 'android';

        function showScreen(featureId: string) {
          featureScreens.forEach(s => s.classList.remove('active'));
          const target = section.querySelector(
            platformBtns.length > 0
              ? `.feature-screen[data-feature="${featureId}"][data-platform="${activePlatform}"]`
              : `.feature-screen[data-feature="${featureId}"]`
          );
          if (target) target.classList.add('active');
        }

        function activate(item: HTMLElement) {
          featureItems.forEach(i => {
            i.classList.toggle('active', i === item);
            i.setAttribute('aria-pressed', String(i === item));
          });
          showScreen(item.getAttribute('data-feature')!);
        }

        function scrollListTo(item: HTMLElement) {
          if (!list) return;
          list.scrollTo({
            top: item.offsetTop - list.offsetTop - list.clientHeight / 2 + item.clientHeight / 2,
            behavior: prefersReducedMotion ? 'auto' : 'smooth',
          });
        }

        featureItems.forEach(i =>
          i.setAttribute('aria-pressed', String(i.classList.contains('active')))
        );

        let autoTimer: ReturnType<typeof setInterval> | null = null;
        let userInteracted = false;
        let sectionInView = false;

        function stopAuto() {
          if (autoTimer) {
            clearInterval(autoTimer);
            autoTimer = null;
          }
        }

        function startAuto() {
          if (userInteracted || prefersReducedMotion || autoTimer) return;
          if (!sectionInView || document.visibilityState === 'hidden') return;
          autoTimer = setInterval(() => {
            const current = featureItems.findIndex(i => i.classList.contains('active'));
            const next = featureItems[(current + 1) % featureItems.length];
            activate(next);
            scrollListTo(next);
          }, 4000);
        }

        section.addEventListener('pointerdown', () => {
          userInteracted = true;
          stopAuto();
        });

        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'hidden') stopAuto();
          else startAuto();
        });

        const autoObserver = new IntersectionObserver(
          entries => {
            entries.forEach(entry => {
              sectionInView = entry.isIntersecting;
              if (entry.isIntersecting) startAuto();
              else stopAuto();
            });
          },
          { threshold: 0.35 }
        );
        autoObserver.observe(section);

        featureItems.forEach(item => {
          item.addEventListener('click', () => {
            activate(item);
            item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          });
        });

        const deviceFrame = section.querySelector('.device-frame-phone');
        if (deviceFrame) deviceFrame.setAttribute('data-active-platform', activePlatform);

        platformBtns.forEach(btn =>
          btn.setAttribute('aria-pressed', String(btn.classList.contains('active')))
        );

        platformBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            platformBtns.forEach(b => {
              b.classList.toggle('active', b === btn);
              b.setAttribute('aria-pressed', String(b === btn));
            });
            activePlatform = btn.getAttribute('data-platform')!;
            if (deviceFrame) deviceFrame.setAttribute('data-active-platform', activePlatform);
            const activeFeature = section.querySelector<HTMLElement>('.feature-item.active');
            if (activeFeature) showScreen(activeFeature.getAttribute('data-feature')!);
          });
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
