---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Pear Notes is a secure, private, and offline-first notebook. End-to-end encrypted with peer-to-peer sync across all your devices. No servers, no cloud leaks.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e0e10" />
    <link rel="icon" type="image/png" href={`${base}icon.png`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${base}icon.png`} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      const header = document.querySelector('.header');
      if (header) {
        window.addEventListener('scroll', () => {
          header.classList.toggle('scrolled', window.scrollY > 40);
        });
      }

      const menuBtn = document.querySelector('.mobile-menu-btn');
      const navLinks = document.querySelector('.nav-links');
      if (menuBtn && navLinks) {
        menuBtn.addEventListener('click', () => {
          navLinks.classList.toggle('open');
          menuBtn.textContent = navLinks.classList.contains('open') ? '✕' : '☰';
        });
        navLinks.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            navLinks.classList.remove('open');
            menuBtn.textContent = '☰';
          });
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

      document.querySelectorAll('.feature-list').forEach(list => {
        const wrap = list.closest('.feature-list-wrap');
        if (!wrap) return;
        const check = () => {
          const atTop = list.scrollTop < 8;
          const atBottom = list.scrollHeight - list.scrollTop - list.clientHeight < 8;
          wrap.classList.toggle('scrolled-top', !atTop);
          wrap.classList.toggle('at-bottom', atBottom);
        };
        check();
        list.addEventListener('scroll', check);
      });

      document.querySelectorAll('.app-showcase').forEach(section => {
        const featureItems = section.querySelectorAll('.feature-item');
        const featureScreens = section.querySelectorAll('.feature-screen');
        const platformBtns = section.querySelectorAll('.platform-toggle-btn');
        let activePlatform = platformBtns.length > 0 ? platformBtns[0].getAttribute('data-platform')! : 'android';

        function showScreen(featureId: string) {
          featureScreens.forEach(s => s.classList.remove('active'));
          const target = section.querySelector(
            platformBtns.length > 0
              ? `.feature-screen[data-feature="${featureId}"][data-platform="${activePlatform}"]`
              : `.feature-screen[data-feature="${featureId}"]`
          );
          if (target) target.classList.add('active');
        }

        featureItems.forEach(item => {
          item.addEventListener('click', () => {
            featureItems.forEach(i => i.classList.remove('active'));
            item.classList.add('active');
            showScreen(item.getAttribute('data-feature')!);
            item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          });
        });

        const deviceFrame = section.querySelector('.device-frame-phone');
        if (deviceFrame) deviceFrame.setAttribute('data-active-platform', activePlatform);

        platformBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            platformBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            activePlatform = btn.getAttribute('data-platform')!;
            if (deviceFrame) deviceFrame.setAttribute('data-active-platform', activePlatform);
            const activeFeature = section.querySelector('.feature-item.active');
            if (activeFeature) showScreen(activeFeature.getAttribute('data-feature')!);
          });
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
