---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="Pear Notes — Private & Encrypted Notes with P2P Sync">
  <div class="dot-grid"></div>
  <Header />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-glow hero-glow-1"></div>
    <div class="hero-glow hero-glow-2"></div>
    <div class="hero-glow hero-glow-3"></div>
    <div class="hero-content">
      <img src={`${base}icon.png`} alt="Pear Notes" class="hero-icon" />
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        End-to-End Encrypted
      </div>
      <h1>
        Your notes,<br />
        <span class="gradient-text">truly private.</span>
      </h1>
      <p class="hero-subtitle">
        Encrypted notes that sync directly between your devices using peer-to-peer connections. No servers. No cloud. No compromises.
      </p>
      <div class="hero-actions">
        <a href="#download" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Get Pear Notes
        </a>
        <a href="#features" class="btn-secondary">
          Explore Features
        </a>
      </div>
      <div class="hero-platforms">
        <span class="platform-available">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18c0 .55.45 1 1 1h1v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h2v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h1c.55 0 1-.45 1-1V7H6v11zM3.5 7C2.67 7 2 7.67 2 8.5v7c0 .83.67 1.5 1.5 1.5S5 16.33 5 15.5v-7C5 7.67 4.33 7 3.5 7zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48A5.84 5.84 0 0 0 12 0c-.96 0-1.86.23-2.66.63L7.85.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31A5.983 5.983 0 0 0 6 6h12c0-2.21-1.2-4.15-2.97-5.19V1.16zM10 4H9V3h1v1zm5 0h-1V3h1v1z"/></svg>
          Android
        </span>
        <span class="platform-soon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83"/><path d="M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"/></svg>
          iOS &middot; Soon
        </span>
        <span class="platform-soon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83"/><path d="M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"/></svg>
          macOS &middot; Soon
        </span>
        <span class="platform-soon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
          Windows &middot; Soon
        </span>
      </div>
    </div>
    <div class="scroll-indicator">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
  </section>

  <!-- Features -->
  <section class="features" id="features">
    <div class="container">
      <div class="features-header fade-in">
        <div class="section-label">Features</div>
        <h2 class="section-title">Everything you need,<br />nothing you don't.</h2>
        <p class="section-subtitle">
          A complete writing experience built around privacy, powered by the Hypercore protocol.
        </p>
      </div>
      <div class="features-grid">
        <div class="feature-card fade-in fade-in-delay-1">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3>End-to-End Encrypted</h3>
          <p>All notes are encrypted on-device with AES-256. Backups are secured with your unique 64-character private key.</p>
        </div>
        <div class="feature-card fade-in fade-in-delay-2">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>P2P Device Sync</h3>
          <p>Sync via Hypercore protocol — devices connect directly over encrypted channels using Hyperswarm and HyperDHT.</p>
        </div>
        <div class="feature-card fade-in fade-in-delay-3">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Offline First</h3>
          <p>Works entirely without internet. Everything is stored locally in an encrypted database on your device.</p>
        </div>
        <div class="feature-card fade-in fade-in-delay-1">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </div>
          <h3>Rich Text Editor</h3>
          <p>Tiptap-powered editor with headings, lists, task lists, blockquotes, code blocks, tables, and text alignment.</p>
        </div>
        <div class="feature-card fade-in fade-in-delay-2">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          </div>
          <h3>Voice Notes</h3>
          <p>Record voice memos with waveform visualization, embed them directly inside your notes, and play back anytime.</p>
        </div>
        <div class="feature-card fade-in fade-in-delay-3">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <h3>Document Scanner</h3>
          <p>Capture, crop, and convert physical pages into digital documents stored in your encrypted media vault.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Mobile App Showcase -->
  <section class="app-showcase" id="mobile" data-section="mobile">
    <div class="container">
      <div class="app-showcase-header fade-in">
        <div class="app-showcase-header-text">
          <div class="section-label">Mobile App</div>
          <h2 class="section-title">Notes on the go,<br />always secure.</h2>
          <p class="section-subtitle">Capture thoughts with voice recording, document scanning, and a Tiptap-powered rich text editor.</p>
        </div>
      </div>
      <div class="app-showcase-body">
        <div class="feature-list-wrap">
        <div class="feature-list">
          <button class="feature-item active" data-feature="folders">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Folders</h4>
              <p>Create, rename, and organize notes into folders with drag-and-drop support.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="notes-list">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Notes List</h4>
              <p>Browse notes grouped by date — today, yesterday, last 7 days, and older.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="search">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Full-Text Search</h4>
              <p>Instant search across all notes with real-time filtering and results.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="editor">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Rich Text Editor</h4>
              <p>Headings, lists, task lists, code blocks, blockquotes, links, and text alignment.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="scanner">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Document Scanner</h4>
              <p>Multi-page scanning, auto-crop, and attach photos or videos from camera.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="voice">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Voice Notes</h4>
              <p>Record with waveform visualization, playback, and embed directly inside notes.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="customize">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Customization</h4>
              <p>8 fonts, adjustable text size, dark/light/system themes, and sort options.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="linked-devices">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Linked Devices</h4>
              <p>View, rename, and manage all connected devices with sync status indicators.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="sync">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>P2P Device Sync</h4>
              <p>Hypercore-based sync with QR code pairing and device management.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="fingerprint">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12C2 6.5 6.5 2 12 2a10 10 0 0 1 8 4"/><path d="M5 19.5C5.5 18 6 15 6 12c0-.7.12-1.37.34-2"/><path d="M17.29 21.02c.12-.6.43-2.3.5-3.02"/><path d="M12 10a2 2 0 0 0-2 2c0 1.02-.1 2.51-.26 4"/><path d="M8.65 22c.21-.66.45-1.32.57-2"/><path d="M14 13.12c0 2.38 0 6.38-1 8.88"/><path d="M2 16h.01"/><path d="M21.8 16c.2-2 .131-5.354 0-6"/><path d="M9 6.8a6 6 0 0 1 9 5.2c0 .47 0 1.17-.02 2"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Fingerprint Matching</h4>
              <p>Verify device identity keys during pairing to prevent man-in-the-middle attacks.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="backup">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Encrypted Backups</h4>
              <p>AES-256 encrypted .pnbk export/import with 64-character recovery key.</p>
            </div>
          </button>
          <button class="feature-item" data-feature="storage">
            <div class="feature-item-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DCA323" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </div>
            <div class="feature-item-text">
              <h4>Storage</h4>
              <p>View storage usage breakdown by images, videos, voice notes, files, and text.</p>
            </div>
          </button>
        </div>
        </div>
        <div class="device-preview">
          <div class="platform-toggle platform-toggle-above">
            <button class="platform-toggle-btn active" data-platform="ios">iOS</button>
            <button class="platform-toggle-btn" data-platform="android">Android</button>
          </div>
          <div class="device-frame device-frame-phone">
            <div class="device-notch"></div>
            <div class="feature-screens">
              <div class="feature-screen" data-feature="editor" data-platform="android">
                <img src={`${base}screenshots/Android/Rich-Text-Editor.png`} alt="Rich Text Editor - Android" />
              </div>
              <div class="feature-screen" data-feature="editor" data-platform="ios">
                <img src={`${base}screenshots/iOS/Rich-Text-Editor.png`} alt="Rich Text Editor - iOS" />
              </div>
              <div class="feature-screen" data-feature="voice" data-platform="android">
                <img src={`${base}screenshots/Android/Voice-Notes.png`} alt="Voice Notes - Android" />
              </div>
              <div class="feature-screen" data-feature="voice" data-platform="ios">
                <img src={`${base}screenshots/iOS/Voice-Notes.png`} alt="Voice Notes - iOS" />
              </div>
              <div class="feature-screen" data-feature="scanner" data-platform="android">
                <img src={`${base}screenshots/Android/Document-Scanner.png`} alt="Document Scanner - Android" />
              </div>
              <div class="feature-screen" data-feature="scanner" data-platform="ios">
                <img src={`${base}screenshots/iOS/Document-Scanner.png`} alt="Document Scanner - iOS" />
              </div>
              <div class="feature-screen" data-feature="sync" data-platform="android">
                <img src={`${base}screenshots/Android/P2P-Device-Sync.png`} alt="P2P Device Sync - Android" />
              </div>
              <div class="feature-screen" data-feature="sync" data-platform="ios">
                <img src={`${base}screenshots/iOS/P2P-Device-Sync.png`} alt="P2P Device Sync - iOS" />
              </div>
              <div class="feature-screen" data-feature="backup" data-platform="android">
                <img src={`${base}screenshots/Android/Encrypted-Backups.png`} alt="Encrypted Backups - Android" />
              </div>
              <div class="feature-screen" data-feature="backup" data-platform="ios">
                <img src={`${base}screenshots/iOS/Encrypted-Backups.png`} alt="Encrypted Backups - iOS" />
              </div>
              <div class="feature-screen" data-feature="search" data-platform="android">
                <img src={`${base}screenshots/Android/Full-Text-Search.png`} alt="Full-Text Search - Android" />
              </div>
              <div class="feature-screen" data-feature="search" data-platform="ios">
                <img src={`${base}screenshots/iOS/Full-Text-Search.png`} alt="Full-Text Search - iOS" />
              </div>
              <div class="feature-screen" data-feature="customize" data-platform="android">
                <img src={`${base}screenshots/Android/Customization.png`} alt="Customization - Android" />
              </div>
              <div class="feature-screen" data-feature="customize" data-platform="ios">
                <img src={`${base}screenshots/iOS/Customization.png`} alt="Customization - iOS" />
              </div>
              <div class="feature-screen" data-feature="notes-list" data-platform="android">
                <img src={`${base}screenshots/Android/Notes-List.png`} alt="Notes List - Android" />
              </div>
              <div class="feature-screen" data-feature="notes-list" data-platform="ios">
                <img src={`${base}screenshots/iOS/Notes-List.png`} alt="Notes List - iOS" />
              </div>
              <div class="feature-screen" data-feature="folders" data-platform="android">
                <img src={`${base}screenshots/Android/Folders.png`} alt="Folders - Android" />
              </div>
              <div class="feature-screen active" data-feature="folders" data-platform="ios">
                <img src={`${base}screenshots/iOS/Folders.png`} alt="Folders - iOS" />
              </div>
              <div class="feature-screen" data-feature="fingerprint" data-platform="android">
                <img src={`${base}screenshots/Android/Fingerprint-Matching.png`} alt="Fingerprint Matching - Android" />
              </div>
              <div class="feature-screen" data-feature="fingerprint" data-platform="ios">
